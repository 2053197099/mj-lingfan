{
  "manifest_version": 3,
  "name": "MJ 灵帆",
  "description": "Midjourney 文生图提示词排队、变量与自动发送助手。",
  "version": "1.0.17",
  "permissions": ["alarms", "downloads", "storage"],
  "host_permissions": [
    "https://www.midjourney.com/*",
    "https://midjourney.com/*",
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.midjourney.com/*",
        "https://midjourney.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css", "icons/icon-16.png", "icons/icon-32.png", "icons/icon-48.png", "icons/icon-128.png"],
      "matches": [
        "https://www.midjourney.com/*",
        "https://midjourney.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "MJ 灵帆",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
